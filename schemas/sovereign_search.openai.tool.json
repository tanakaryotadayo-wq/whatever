{
  "type": "function",
  "function": {
    "name": "sovereign_search",
    "description": "Unified search over GitHub, Hugging Face, and/or Akashic DB via sovereign-search. Returns ranked JSON results with scores, sources, dedup count, and evidence previews.",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {"type": "string", "description": "Search query. Example: 'tauri pty session' or 'react hooks'."},
        "top": {"type": "integer", "minimum": 1, "maximum": 50, "default": 12, "description": "Maximum returned results."},
        "source": {"type": "string", "enum": ["all", "github", "akashic", "hf"], "default": "all", "description": "Restrict search source."},
        "no_hf": {"type": "boolean", "default": false, "description": "Skip Hugging Face when source is all."},
        "github_per_page": {"type": "integer", "minimum": 1, "maximum": 100, "default": 20, "description": "GitHub result page size."},
        "graph_depth": {"type": "integer", "minimum": 0, "maximum": 4, "default": 1, "description": "Akashic graph expansion depth."},
        "db": {"type": ["string", "null"], "default": null, "description": "Optional Akashic DB path."},
        "timeout_sec": {"type": "integer", "minimum": 5, "maximum": 600, "default": 90, "description": "Execution timeout."}
      },
      "required": ["query"],
      "additionalProperties": false
    }
  }
}
